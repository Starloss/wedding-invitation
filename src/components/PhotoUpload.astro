---

---

<div class="photo-upload-container">
  <div class="photo-heading">
    <span class="photo-icon-wrap" aria-hidden="true">
      <img src="/camara.svg" alt="" class="photo-heading-icon" />
    </span>
    <h2>Comparte tus Fotos</h2>
  </div>
  <p>
    ¡Ayúdanos a capturar momentos especiales compartiendo tus fotos del evento!
  </p>

  <div class="upload-form">
    <p class="upload-demo-banner">
      🎭 <strong>Modo demo</strong> — la subida de fotos está simulada. Selecciona
      imágenes para ver el flujo visual.
    </p>

    <input
      type="file"
      id="photo-input"
      accept="image/*"
      multiple
      style="display: none;"
    />
    <button id="select-photos-btn" class="btn-select">Seleccionar Fotos</button>

    <div id="preview-container" class="preview-container"></div>

    <button id="upload-btn" class="btn-upload" style="display: none;">
      Subir Fotos (Demo)
    </button>

    <div id="upload-message" class="message"></div>
  </div>
</div>

<style>
  .photo-upload-container {
    background: var(--surface);
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 0;
    box-shadow: var(--shadow-sm);
    max-width: none;
    margin: 0;
  }

  .photo-upload-container > p {
    text-align: center;
  }

  .photo-heading {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
  }

  .photo-icon-wrap {
    position: relative;
    display: inline-block;
    width: 34px;
    height: 34px;
  }

  .photo-heading-icon {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    animation: camera-bob 5.2s ease-in-out infinite;
  }

  .upload-form {
    margin-top: 1.5rem;
  }

  .upload-demo-banner {
    background: #fff8ec;
    border: 1px solid #e5c97a;
    border-radius: 8px;
    padding: 0.65rem 0.9rem;
    font-size: 1.05rem;
    color: #7a5a1e;
    text-align: left;
    margin-bottom: 1rem;
  }

  .btn-select {
    background: var(--primary);
    border-color: #5f7556;
    color: #fff;
    width: 100%;
    margin-bottom: 1rem;
  }

  .btn-select:hover {
    background: #5f7556;
  }

  .btn-upload {
    background: var(--primary);
    border-color: #5f7556;
    color: #fff;
    width: 100%;
    margin-top: 1rem;
  }

  .btn-upload:hover {
    background: #5f7556;
  }

  .preview-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 0.6rem;
    margin-top: 0.5rem;
  }

  .preview-container img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 4px;
  }

  .message {
    margin-top: 0.8rem;
    padding: 0.7rem 0.9rem;
    border-radius: 5px;
    font-weight: 600;
    font-size: 1.1rem;
    display: none;
  }

  .message.success {
    background: var(--primary-soft);
    color: var(--primary);
    border: 1px solid #c6d8bf;
    display: block;
  }

  .message.error {
    background: #f8eaea;
    color: var(--danger);
    border: 1px solid #e0b0b0;
    display: block;
  }

  @keyframes camera-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }
</style>

<script>
  const photoInput = document.getElementById(
    "photo-input",
  ) as HTMLInputElement | null;
  const selectBtn = document.getElementById(
    "select-photos-btn",
  ) as HTMLButtonElement | null;
  const uploadBtn = document.getElementById(
    "upload-btn",
  ) as HTMLButtonElement | null;
  const previewContainer = document.getElementById(
    "preview-container",
  ) as HTMLElement | null;
  const messageEl = document.getElementById(
    "upload-message",
  ) as HTMLElement | null;

  selectBtn?.addEventListener("click", () => photoInput?.click());

  photoInput?.addEventListener("change", () => {
    const files = photoInput.files;
    if (!files || files.length === 0) return;
    if (previewContainer) previewContainer.innerHTML = "";
    Array.from(files).forEach((file) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = document.createElement("img");
        img.src = e.target?.result as string;
        img.alt = file.name;
        previewContainer?.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
    if (uploadBtn) uploadBtn.style.display = "block";
    if (messageEl) messageEl.className = "message";
  });

  uploadBtn?.addEventListener("click", async () => {
    if (uploadBtn) {
      uploadBtn.disabled = true;
      uploadBtn.textContent = "Subiendo...";
    }

    // DEMO: simulate upload delay
    await new Promise((resolve) => setTimeout(resolve, 1200));

    const count = photoInput?.files?.length ?? 0;

    if (uploadBtn) {
      uploadBtn.disabled = false;
      uploadBtn.style.display = "none";
      uploadBtn.textContent = "Subir Fotos (Demo)";
    }

    if (previewContainer) previewContainer.innerHTML = "";

    if (messageEl) {
      messageEl.textContent = `✅ ${count} ${count === 1 ? "foto subida" : "fotos subidas"} exitosamente. (Demo — no se guardaron)`;
      messageEl.className = "message success";
    }
  });
</script>
